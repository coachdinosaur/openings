{
  "name": "catalan-b2-vertical-prototype",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "start": "vinext start",
    "postinstall": "node scripts/patch-vinext-static.mjs",
    "chapters:sync": "node scripts/chapter-system.mjs sync",
    "chapters:check": "node scripts/chapter-system.mjs check",
    "chapters:inspect": "node scripts/chapter-system.mjs inspect",
    "chapters:prepare": "node scripts/chapter-system.mjs prepare",
    "chapters:crops": "python scripts/extract_chessboard_crops.py",
    "chapters:validate-lesson": "node scripts/validate-chapter-lesson.mjs",
    "chapters:verify-import": "node scripts/verify-chapter-import.mjs",
    "test": "npm run chapters:check && npm run build && node --test tests/prototype.test.mjs tests/stockfish-client.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next"
  },
  "dependencies": {
    "chess.js": "^1.4.0",
    "next": "16.2.6",
    "pdfjs-dist": "6.1.200",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
